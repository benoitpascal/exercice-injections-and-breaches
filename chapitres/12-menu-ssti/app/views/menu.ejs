<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Le Menu du Jour - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" /><link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div><div class="lanterne droite"></div>
  <div class="enseigne"><span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span></div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">12</span> Le Menu du Jour</span>
      <span class="badge-danger">BRECHE : SSTI</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">Le Menu du Jour</h1>
      <p class="sous-titre">Compose l'annonce du menu. Tu peux inserer le plat du jour avec <code>&lt;%= plat %&gt;</code>.</p>

      <form method="POST" action="/menu" class="bloc-form">
        <textarea class="champ" name="message" rows="3" placeholder="Ex : Au menu ce soir : <%%= plat %>"><%= modele %></textarea>
        <button class="bouton-pixel" type="submit">Afficher le menu</button>
      </form>

      <% if (erreur) { %><p class="erreur-doc"><%= erreur %></p><% } %>

      <% if (rendu !== null) { %>
        <p class="doc-titre">Annonce affichee :</p>
        <pre class="doc-contenu"><%= rendu %></pre>
      <% } %>
    </section>

    <div class="hud"><span>APPRENTI GARDIEN</span><span class="coeurs">&lt;3 &lt;3 &lt;3</span><span>SALLE 12 / 17</span></div>
  </main>
</body>
</html>
