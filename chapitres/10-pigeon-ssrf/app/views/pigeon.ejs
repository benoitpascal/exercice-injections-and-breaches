<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Le Pigeon Voyageur - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" /><link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div><div class="lanterne droite"></div>
  <div class="enseigne"><span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span></div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">10</span> Le Pigeon Voyageur</span>
      <span class="badge-danger">BRECHE : SSRF</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">Le Pigeon Voyageur</h1>
      <p class="sous-titre">Indique une adresse, et le pigeon ira te rapporter ce qui s'y trouve.</p>

      <form method="POST" action="/envoyer-pigeon" class="bloc-form">
        <input class="champ" type="text" name="url" value="<%= url %>" placeholder="Adresse a aller chercher" />
        <button class="bouton-pixel" type="submit">Envoyer le pigeon</button>
      </form>

      <p class="note-discrete">Adresses connues du village : <code>http://localhost:9000/tableau-du-village</code>, <code>http://localhost:9000/avis-de-foire</code></p>

      <% if (erreur) { %><p class="erreur-doc"><%= erreur %></p><% } %>

      <% if (contenu !== null) { %>
        <p class="doc-titre">Le pigeon a rapporte de "<%= url %>" :</p>
        <pre class="doc-contenu"><%= contenu %></pre>
      <% } %>
    </section>

    <div class="hud"><span>APPRENTI GARDIEN</span><span class="coeurs">&lt;3 &lt;3 &lt;3</span><span>SALLE 10 / 17</span></div>
  </main>
</body>
</html>
