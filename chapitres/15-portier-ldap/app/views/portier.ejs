<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Le Portier - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" /><link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div><div class="lanterne droite"></div>
  <div class="enseigne"><span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span></div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">15</span> Le Portier</span>
      <span class="badge-danger">BRECHE : INJECTION LDAP</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">Le Portier de l'Auberge</h1>
      <p class="sous-titre">Donne ton identifiant et ton mot de passe pour entrer.</p>

      <form method="POST" action="/entrer" class="bloc-form">
        <input class="champ" type="text" name="uid" placeholder="Identifiant" value="<%= uid %>" autocomplete="off" />
        <input class="champ" type="text" name="motDePasse" placeholder="Mot de passe" autocomplete="off" />
        <button class="bouton-pixel" type="submit">Entrer</button>
      </form>

      <% if (resultat) { %>
        <p class="doc-titre">Filtre envoye au portier :</p>
        <pre class="doc-contenu"><%= resultat.filtre %></pre>
        <% if (resultat.ok) { %>
          <p class="msg-ok">Le portier s'ecarte. Bienvenue, <strong><%= resultat.entree.uid %></strong> (<%= resultat.entree.role %>).</p>
          <% if (resultat.entree.secret) { %>
            <p class="doc-titre">Note confidentielle laissee a ce compte :</p>
            <pre class="doc-contenu"><%= resultat.entree.secret %></pre>
          <% } %>
        <% } else { %>
          <p class="erreur-doc">Le portier ne bouge pas. Identifiant ou mot de passe refuse.</p>
        <% } %>
      <% } %>
    </section>

    <div class="hud"><span>APPRENTI GARDIEN</span><span class="coeurs">&lt;3 &lt;3 &lt;3</span><span>SALLE 15 / 17</span></div>
  </main>
</body>
</html>
