<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>L'Atelier - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" /><link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div><div class="lanterne droite"></div>
  <div class="enseigne"><span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span></div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">13</span> L'Atelier</span>
      <span class="badge-danger">BRECHE : DESERIALISATION</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">Le Plan d'Etabli</h1>
      <p class="sous-titre">Colle un plan sauvegarde pour le restaurer dans l'atelier.</p>

      <form method="POST" action="/restaurer" class="bloc-form">
        <textarea class="champ" name="plan" rows="3" placeholder="Plan sauvegarde..."><%= plan %></textarea>
        <button class="bouton-pixel" type="submit">Restaurer le plan</button>
      </form>

      <% if (erreur) { %><p class="erreur-doc"><%= erreur %></p><% } %>

      <% if (restaure !== null) { %>
        <p class="doc-titre">Plan restaure :</p>
        <pre class="doc-contenu"><%= restaure %></pre>
      <% } %>
    </section>

    <div class="hud"><span>APPRENTI GARDIEN</span><span class="coeurs">&lt;3 &lt;3 &lt;3</span><span>SALLE 13 / 17</span></div>
  </main>
</body>
</html>
