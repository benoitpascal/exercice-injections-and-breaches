<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Le Journal de Bord - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" /><link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div><div class="lanterne droite"></div>
  <div class="enseigne"><span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span></div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">16</span> Le Journal de Bord</span>
      <span class="badge-danger">BRECHE : LOG INJECTION</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">Le Journal de Bord</h1>
      <p class="sous-titre">Annonce ton arrivee : le portier l'inscrit au journal.</p>

      <form method="POST" action="/arriver" class="bloc-form">
        <textarea class="champ" name="nom" rows="2" placeholder="Ton nom"></textarea>
        <button class="bouton-pixel" type="submit">M'annoncer</button>
      </form>

      <p class="doc-titre">Journal de bord de l'auberge :</p>
      <pre class="doc-contenu"><%= journal %></pre>
    </section>

    <div class="hud"><span>APPRENTI GARDIEN</span><span class="coeurs">&lt;3 &lt;3 &lt;3</span><span>SALLE 16 / 17</span></div>
  </main>
</body>
</html>
