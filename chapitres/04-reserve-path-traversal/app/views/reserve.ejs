<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>La Reserve - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" /><link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div><div class="lanterne droite"></div>
  <div class="enseigne"><span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span></div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">04</span> La Reserve</span>
      <span class="badge-danger">BRECHE : PATH TRAVERSAL</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">La Reserve</h1>
      <p class="sous-titre">Consulte les documents ranges dans la reserve de l'auberge.</p>

      <p class="liste-titre">Documents disponibles :</p>
      <ul class="docs">
        <% fichiers.forEach(function (f) { %>
          <li><a href="/lire?fichier=<%= encodeURIComponent(f) %>"><%= f %></a></li>
        <% }); %>
      </ul>

      <form method="GET" action="/lire" class="bloc-form">
        <input class="champ" type="text" name="fichier" value="<%= demande || '' %>" placeholder="Nom du document a lire" />
        <button class="bouton-pixel" type="submit">Lire</button>
      </form>

      <% if (erreur) { %>
        <p class="erreur-doc"><%= erreur %></p>
      <% } %>

      <% if (contenu !== null) { %>
        <p class="doc-titre">Contenu de "<%= demande %>" :</p>
        <%# Le contenu du fichier est affiche avec une balise echappee : pas de XSS ici. %>
        <pre class="doc-contenu"><%= contenu %></pre>
      <% } %>
    </section>

    <div class="hud"><span>APPRENTI GARDIEN</span><span class="coeurs">&lt;3 &lt;3 &lt;3</span><span>SALLE 04 / 17</span></div>
  </main>
</body>
</html>
