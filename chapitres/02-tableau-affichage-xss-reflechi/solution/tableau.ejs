<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Tableau d'Affichage - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" />
  <link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div>
  <div class="lanterne droite"></div>

  <div class="enseigne">
    <span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span>
  </div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">02</span> Le Tableau d'Affichage</span>
      <span class="badge-danger">BRECHE : XSS REFLECHI</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">Avis de Quete</h1>
      <p class="sous-titre">Cherche un avis punaise au tableau de l'auberge.</p>

      <form method="GET" action="/" class="bloc-form">
        <%# La valeur du champ reutilise le terme, mais avec une balise echappee : ce point est protege. %>
        <input class="champ" type="text" name="q" value="<%= q %>" placeholder="Cherche un avis (loup, toit, epices...)" />
        <button class="bouton-pixel" type="submit">Chercher</button>
      </form>

      <% if (q) { %>
        <p class="recherche-info">
          <%# CORRIGE : on reaffiche le terme recherche avec une balise echappee (egal au lieu de tiret). %>
          <%# Le texte venu de l URL est neutralise : un script s affiche en texte inerte. %>
          Resultats pour : "<%= q %>"
        </p>
      <% } %>

      <section class="liste">
        <% resultats.forEach(function (a) { %>
          <article class="carte">
            <p class="auteur"><%= a.titre %></p>
            <div class="contenu"><%= a.details %></div>
          </article>
        <% }); %>
        <% if (q && resultats.length === 0) { %>
          <p class="livre-vide">Aucun avis ne correspond a ta recherche.</p>
        <% } %>
      </section>
    </section>

    <div class="hud">
      <span>APPRENTI GARDIEN</span>
      <span class="coeurs">&lt;3 &lt;3 &lt;3</span>
      <span>SALLE 02 / 17</span>
    </div>
  </main>
</body>
</html>
