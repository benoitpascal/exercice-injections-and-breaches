<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" /><meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Les Cuisines - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" /><link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div><div class="lanterne droite"></div>
  <div class="enseigne"><span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span></div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">11</span> Les Cuisines</span>
      <span class="badge-danger">BRECHE : COMMAND INJECTION</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">Le Garde-Manger</h1>
      <p class="sous-titre">Demande au marmiton de compter un ingredient en stock.</p>

      <form method="POST" action="/compter" class="bloc-form">
        <input class="champ" type="text" name="ingredient" value="<%= ingredient %>" placeholder="Ex : farine" />
        <button class="bouton-pixel" type="submit">Compter</button>
      </form>

      <% if (commande) { %>
        <p class="doc-titre">Commande lancee par le marmiton :</p>
        <pre class="doc-cmd"><%= commande %></pre>
      <% } %>

      <% if (sortie !== null) { %>
        <p class="doc-titre">Resultat :</p>
        <pre class="doc-contenu"><%= sortie %></pre>
      <% } %>
    </section>

    <div class="hud"><span>APPRENTI GARDIEN</span><span class="coeurs">&lt;3 &lt;3 &lt;3</span><span>SALLE 11 / 17</span></div>
  </main>
</body>
</html>
