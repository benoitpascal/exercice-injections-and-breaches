<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Livre d'Or - L'Auberge du Pixel</title>
  <link rel="stylesheet" href="/theme.css" />
  <link rel="stylesheet" href="/page.css" />
</head>
<body>
  <div class="lanterne gauche"></div>
  <div class="lanterne droite"></div>

  <div class="enseigne">
    <span class="planche"><span class="clous">+</span> L'AUBERGE DU PIXEL <span class="clous">+</span></span>
  </div>

  <main class="salle">
    <div class="entete-salle">
      <span class="titre"><span class="num">01</span> Le Livre d'Or</span>
      <span class="badge-danger">BRECHE : XSS STOCKE</span>
    </div>

    <section class="panneau">
      <h1 class="titre-page">Livre d'Or</h1>
      <p class="sous-titre">Laisse un mot avant de reprendre la route, voyageur.</p>

      <form method="POST" action="/signer" class="bloc-form">
        <input class="champ" type="text" name="auteur" placeholder="Ton nom de voyageur" maxlength="40" />
        <textarea class="champ" name="message" placeholder="Ton message pour les prochains visiteurs..." rows="3" required></textarea>
        <button class="bouton-pixel" type="submit">Signer le livre</button>
      </form>

      <section class="liste">
        <% livreDor.forEach(function (entree) { %>
          <article class="carte">
            <%# Le nom de l'auteur est affiche avec une balise echappee : il est protege. %>
            <p class="auteur"><%= entree.auteur %></p>

            <%# ATTENTION - TODO securiser : la ligne ci-dessous affiche le message %>
            <%# avec une balise NON echappee. Le texte tape par le visiteur est injecte %>
            <%# tel quel dans la page : c'est la faille a corriger (acte 4). %>
            <div class="contenu"><%- entree.message %></div>
          </article>
        <% }); %>
      </section>
    </section>

    <div class="hud">
      <span>APPRENTI GARDIEN</span>
      <span class="coeurs">&lt;3 &lt;3 &lt;3</span>
      <span>SALLE 01 / 17</span>
    </div>
  </main>
</body>
</html>
